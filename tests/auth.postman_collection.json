{
  "info": {
    "name": "CodingWBla 3D Store — Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "2. Register — success",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "3. Register — duplicate (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 409', () => pm.response.to.have.status(409));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "4. Register — short password (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"newguy\",\n  \"email\": \"newguy@example.com\",\n  \"password\": \"short\"\n}"
        }
      }
    },
    {
      "name": "5. Register — missing email (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"noemail\",\n  \"email\": \"\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "6. Register — invalid username chars (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"bad user name!\",\n  \"email\": \"bad@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "7. Login — success (auto-saves token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
              "pm.test('Has user', () => pm.expect(pm.response.json().user).to.be.an('object'));",
              "pm.collectionVariables.set('token', pm.response.json().token);",
              "console.log('Token saved:', pm.response.json().token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "8. Login — seed admin (auto-saves token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Role is admin', () => pm.expect(pm.response.json().user.role).to.equal('admin'));",
              "pm.collectionVariables.set('token', pm.response.json().token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"seed@3dstore.dev\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "9. Login — wrong password (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"wrongpassword\"\n}"
        }
      }
    },
    {
      "name": "10. Login — non-existent user (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ghost@nowhere.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "11. Login — missing fields (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\"\n}"
        }
      }
    },
    {
      "name": "12. Get me — authenticated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Has user object', () => pm.expect(pm.response.json().user).to.be.an('object'));",
              "pm.test('No password field', () => pm.expect(pm.response.json().user.password).to.be.undefined);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/user"
      }
    },
    {
      "name": "13. Get me — no token (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/user"
      }
    },
    {
      "name": "14. Get me — bad token (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', () => pm.response.to.have.status(401));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer totallynotavalidtoken" }],
        "url": "{{baseUrl}}/api/user"
      }
    },
    {
      "name": "15. Reset password — request email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
              "pm.test('Has message', () => pm.expect(pm.response.json().message).to.be.a('string'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/reset-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\"\n}"
        }
      }
    },
    {
      "name": "16. Reset password — fake email still 200 (no leak)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 (no email leak)', () => pm.response.to.have.status(200));",
              "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/reset-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"doesnotexist@nowhere.com\"\n}"
        }
      }
    },
    {
      "name": "17. Reset password — bad token (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/reset-password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"fakeinvalidtoken\",\n  \"newPassword\": \"NewPassword456!\"\n}"
        }
      }
    },
    {
      "name": "18. Reset password — missing both fields (400)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400', () => pm.response.to.have.status(400));",
              "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/auth/reset-password",
        "body": {
          "mode": "raw",
          "raw": "{}"
        }
      }
    }
  ]
}
