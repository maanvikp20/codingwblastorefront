    {
      "name": "── BLOG — Public ───────────────────",
      "item": [
        {
          "name": "B1. List published posts — no filters",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Has posts array', () => pm.expect(pm.response.json().posts).to.be.an('array'));",
                  "pm.test('Has total', () => pm.expect(pm.response.json().total).to.be.a('number'));",
                  "pm.test('No draft posts returned', () => {",
                  "  pm.response.json().posts.forEach(p => pm.expect(p.status).to.not.equal('draft'));",
                  "});",
                  "pm.test('Content field omitted', () => {",
                  "  if (pm.response.json().posts.length > 0)",
                  "    pm.expect(pm.response.json().posts[0].content).to.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/blog"
          }
        },
        {
          "name": "B2. List posts — filter by category=tutorial",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are tutorial', () => {",
                  "  pm.response.json().posts.forEach(p => pm.expect(p.category).to.equal('tutorial'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/blog?category=tutorial",
              "query": [{ "key": "category", "value": "tutorial" }]
            }
          }
        },
        {
          "name": "B3. List posts — paginate page 1 limit 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Max 2 results', () => pm.expect(pm.response.json().posts.length).to.be.at.most(2));",
                  "pm.test('Page is 1', () => pm.expect(pm.response.json().page).to.equal(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/blog?page=1&limit=2",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "2" }
              ]
            }
          }
        }
      ]
    },

