{
  "info": {
    "name": "CodingWBla 3D Store — Products & Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3000" },
    { "key": "token",      "value": "PASTE_USER_JWT_HERE" },
    { "key": "adminToken", "value": "PASTE_ADMIN_JWT_HERE" },
    { "key": "productId",  "value": "" },
    { "key": "commentId",  "value": "" }
  ],
  "item": [

    {
      "name": "── SETUP ──────────────────────────",
      "item": [
        {
          "name": "S1. Login as seed admin (saves adminToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Role is admin', () => pm.expect(pm.response.json().user.role).to.equal('admin'));",
                  "pm.collectionVariables.set('adminToken', pm.response.json().token);",
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seed@3dstore.dev\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "S2. Login as regular user (saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        }
      ]
    },

